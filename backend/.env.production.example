# Backend production profile
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Security
JWT_SECRET=replace-with-strong-32plus-byte-secret
JWT_REFRESH_EXPIRATION_MS=2592000000
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app
REQUIRE_HTTPS=true
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAME_SITE=Strict

# Admin bootstrap
ADMIN_EMAIL=your-admin@email.com
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_NAME=Pranjal Admin

# OAuth2 (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH2_REDIRECT_URL=https://your-frontend-domain.vercel.app/oauth2/success

# Uploads (Cloudinary free tier)
FILE_UPLOAD_ENABLED=true
UPLOAD_PROVIDER=cloudinary
UPLOAD_MAX_SIZE=5242880
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=boutique-services

# Optional webhook alerts (Discord/Slack/Telegram webhook gateway)
ALERTS_ENABLED=true
ALERTS_WEBHOOK_URL=
ALERTS_WEBHOOK_TOKEN=

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=15
RATE_LIMIT_WRITE_PER_MINUTE=50
RATE_LIMIT_DEFAULT_PER_MINUTE=150
ADMIN_MAX_ITEMS=500
